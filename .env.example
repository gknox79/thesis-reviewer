# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated access codes for students
ACCESS_CODES=THESIS-ANNA-2026,THESIS-BOB-2026,THESIS-CAROL-2026

# Vercel KV (auto-populated when you create a KV store in Vercel dashboard)
# For local development without Vercel KV, the app falls back to in-memory storage
KV_REST_API_URL=
KV_REST_API_TOKEN=
